# 토스증권 Open API 자격증명 (토스증권 WTS > 설정 > Open API 에서 발급)
# 이 파일을 .env 로 복사해서 값을 채우세요. .env 는 커밋되지 않습니다.
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 계좌번호(X-Tossinvest-Account 헤더). 비워두면 /accounts 로 자동 조회합니다.
TOSS_ACCOUNT_SEQ=

# 안전: 정확히 "true" 일 때만 실주문 전송. 그 외에는 모두 드라이런(로그만).
LIVE_TRADING=false

# --- 전략/운영 파라미터 (선택, 미설정 시 기본값) ---
# RSI_PERIOD=14
# RSI_BUY_THRESHOLD=30
# RSI_SELL_THRESHOLD=70
# WATCH_COUNT=20
# CYCLE_INTERVAL_SEC=60
# ORDER_AMOUNT_KRW=100000

# --- 전략 모드 ---
# composite = RSI + 뉴스 감성 점수 합산(기본) / rsi = RSI 단독
# STRATEGY_MODE=composite

# --- 뉴스 전략 (composite 모드에서 사용) ---
# NEWS_ENABLED=true            # 뉴스 수집/분석 on/off
# NEWS_LOOKBACK_DAYS=7         # 최근 며칠 기사까지
# NEWS_TTL_MIN=15              # 종목별 뉴스 캐시 유효시간(분)
# WEIGHT_RSI=0.5              # 종합점수에서 RSI 가중치
# WEIGHT_NEWS=0.3            # 종합점수에서 뉴스 감성 가중치
# WEIGHT_MA=0.2             # 종합점수에서 이동평균 추세 가중치(정배열+/역배열-)
# BUY_SCORE_THRESHOLD=0.5    # 종합점수 이 값 이상이면 매수
# SELL_SCORE_THRESHOLD=-0.5  # 종합점수 이 값 이하 & 보유중이면 매도

# --- 매수 타이밍 필터 (BUY 신호에만 적용) ---
# HIGH_GUARD_PCT=0.8   # 최근 밴드 위치가 이 값(0~1) 이상=고점 근처면 매수 금지 (1 이상이면 off)
# REBOUND_CONFIRM=true # 직전 종가보다 오른 뒤에만 매수(반등 확인, 칼날잡기 방지)

# --- 안전 한도 (선택, 미설정 시 기본값) ---
# MAX_ORDER_KRW=100000
# MAX_DAILY_BUY_KRW=500000
# MAX_WEEKLY_BUY_KRW=200000   # 한 주(월~일) 총 매수 최대 금액
# MAX_DAILY_BUY_COUNT=1       # 하루 최대 매수 횟수
# MAX_POSITIONS=5

# --- 웹 대시보드 ---
# WEB_PORT=3000
# WEB_HOST=0.0.0.0        # 리버스 프록시(Caddy) 뒤라면 127.0.0.1 권장
# 공개 배포 시 반드시 설정 (안 하면 잔고/포지션이 인증 없이 노출됩니다)
# DASHBOARD_USER=
# DASHBOARD_PASS=
